# Copie para .env.local e preencha conforme necessário.
# (Nenhuma variável é obrigatória na Fase 0.)

# Fuso horário da aplicação
TZ=America/Sao_Paulo

# Banco de dados
# DATABASE_URL=postgresql://usuario:senha@host:5432/tarefo
# DATABASE_SSL=true   # ative ao conectar por URL externa com SSL

# Segredo para assinar a sessão de login (use um valor aleatório longo)
# SESSION_SECRET=troque-por-um-valor-aleatorio-bem-longo

# --- Integrações (preencher quando recebermos as credenciais) ---
# E-mail (Locaweb / SMTP)
# SMTP_HOST=email-ssl.com.br
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=

# WhatsApp (Z-API)
# ZAPI_INSTANCE=
# ZAPI_TOKEN=

# SAC — token dos webhooks de entrada (e-mail/Superlógica/WhatsApp)
# Endpoints: POST /api/sac/email | /api/sac/superlogica | /api/sac/whatsapp
# Header: X-SAC-TOKEN: <valor>
# SAC_WEBHOOK_TOKEN=

# Cron diário (00:00 BRT) — token do endpoint /api/cron. Ver CRON_SETUP.md
# CRON_SECRET=

# IA (geração de quiz/conteúdo/copy) — Claude / Anthropic
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-6

# IA de imagens — ChatGPT / OpenAI (Time Line da Intranet e capa dos treinamentos)
# OPENAI_API_KEY=
# OPENAI_IMAGE_MODEL=gpt-image-1

# ERP (Superlógica)
# SUPERLOGICA_APP_TOKEN=
# SUPERLOGICA_ACCESS_TOKEN=

# Observação: todas as chaves acima também podem ser configuradas pela tela "API"
# do sistema (perfil Administrador), sem precisar mexer nestas variáveis.
