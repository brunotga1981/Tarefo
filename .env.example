# Copie para .env.local e preencha conforme necessário.
# (Nenhuma variável é obrigatória na Fase 0.)

# Fuso horário da aplicação
TZ=America/Sao_Paulo

# --- Fase 2: banco de dados ---
# DATABASE_URL=postgresql://usuario:senha@host:5432/tarefo

# --- Integrações (preencher quando recebermos as credenciais) ---
# E-mail (Locaweb / SMTP)
# SMTP_HOST=email-ssl.com.br
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=

# WhatsApp (Z-API)
# ZAPI_INSTANCE=
# ZAPI_TOKEN=

# ERP (Superlógica)
# SUPERLOGICA_APP_TOKEN=
# SUPERLOGICA_ACCESS_TOKEN=
