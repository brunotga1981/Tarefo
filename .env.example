# Copie para .env.local e preencha conforme necessário.
# (Nenhuma variável é obrigatória na Fase 0.)

# Fuso horário da aplicação
TZ=America/Sao_Paulo

# Banco de dados
# DATABASE_URL=postgresql://usuario:senha@host:5432/tarefo
# DATABASE_SSL=true   # ative ao conectar por URL externa com SSL

# Segredo para assinar a sessão de login (use um valor aleatório longo)
# SESSION_SECRET=troque-por-um-valor-aleatorio-bem-longo

# --- Integrações (preencher quando recebermos as credenciais) ---
# E-mail (Locaweb / SMTP)
# SMTP_HOST=email-ssl.com.br
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=

# WhatsApp (Z-API)
# ZAPI_INSTANCE=
# ZAPI_TOKEN=

# ERP (Superlógica)
# SUPERLOGICA_APP_TOKEN=
# SUPERLOGICA_ACCESS_TOKEN=
